# Environment configuration for sec-selfstorage
# Copy this file to .env and fill in your values

# REQUIRED: 32-byte AES-256 encryption key (64 hex characters)
# Generate with: openssl rand -hex 32
SYSTEM_ENCRYPTION_KEY=

# REQUIRED: Secret for signing session cookies
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# WebAuthn Relying Party settings
# RP_ID must match the domain your app is served from (no port, no protocol)
RP_ID=localhost
RP_NAME=SecSelfStorage
# RP_ORIGIN must match the exact origin (protocol + host + optional port)
RP_ORIGIN=http://localhost:4000

# Server port
PORT=4000

# Data directory for SQLite database
DATA_DIR=./data
